{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Serenity Chan Valuation Inputs",
  "type": "object",
  "required": [
    "symbol",
    "currency",
    "as_of_date",
    "regular_market_price",
    "total_shares",
    "total_market_cap",
    "source_basis",
    "share_count_basis",
    "market_cap_basis"
  ],
  "properties": {
    "symbol": { "type": "string", "minLength": 1 },
    "name": { "type": "string" },
    "currency": { "type": "string", "minLength": 1 },
    "exchange": { "type": "string" },
    "as_of_date": { "type": "string" },
    "regular_market_price": { "type": "number", "exclusiveMinimum": 0 },
    "regular_market_time": { "type": "string" },
    "total_shares": { "type": "number", "exclusiveMinimum": 0 },
    "float_shares": { "type": ["number", "null"], "minimum": 0 },
    "total_market_cap": { "type": "number", "exclusiveMinimum": 0 },
    "float_market_cap": { "type": ["number", "null"], "minimum": 0 },
    "source_basis": {
      "type": "string",
      "enum": ["official_disclosure", "licensed_structured", "quote_derived_preflight", "manual_verified"]
    },
    "share_count_basis": { "type": "string", "minLength": 1 },
    "market_cap_basis": { "type": "string", "minLength": 1 },
    "requires_l0_l1_verification": { "type": "boolean" },
    "raw_field_indices": {
      "type": "object",
      "additionalProperties": { "type": ["integer", "string"] }
    }
  },
  "additionalProperties": true
}
