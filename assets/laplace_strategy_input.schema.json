{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Serenity Laplace Strategy Input",
  "type": "object",
  "required": [
    "contract_type",
    "schema_version",
    "generated_at",
    "source_report_path",
    "strategy_input_ready",
    "companion_skill",
    "decision_context",
    "comparison_summary",
    "observed_facts",
    "forecast_variables",
    "strategy_questions",
    "laplace_execution",
    "ledger_seed",
    "discovery_context"
  ],
  "properties": {
    "contract_type": {
      "type": "string",
      "const": "serenity_laplace_strategy_input"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "generated_at": {
      "type": "string"
    },
    "source_report_path": {
      "type": "string"
    },
    "strategy_input_ready": {
      "type": "object",
      "required": ["status", "source_report_type", "report_readiness", "ai_review_statuses", "policy"],
      "properties": {
        "status": { "type": "string", "const": "READY" },
        "source_report_type": { "type": "string", "const": "completed_ai_research" },
        "report_readiness": {
          "type": "object",
          "required": ["stage", "delivery_allowed"],
          "properties": {
            "stage": { "type": "string", "const": "FINAL_REPORT_READY" },
            "delivery_allowed": { "type": "boolean", "const": true }
          },
          "additionalProperties": true
        },
        "ai_review_statuses": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["COMPLETED", "FAILED_INSUFFICIENT_EVIDENCE", "CONFLICT_WITH_DATA"]
          }
        },
        "policy": { "type": "string" }
      },
      "additionalProperties": true
    },
    "companion_skill": {
      "type": "object",
      "required": ["name", "path", "entrypoint"],
      "properties": {
        "name": {"type": "string"},
        "path": {"type": "string"},
        "entrypoint": {"type": "string"}
      },
      "additionalProperties": true
    },
    "decision_context": {
      "type": "object",
      "required": ["object", "horizon", "geography", "decision_use", "default_profile"],
      "properties": {
        "object": {"type": "string"},
        "horizon": {"type": "string"},
        "geography": {"type": "string"},
        "decision_use": {"type": "string"},
        "default_profile": {"type": "string"}
      },
      "additionalProperties": true
    },
    "comparison_summary": {
      "type": "object",
      "required": ["candidate_count", "as_of", "semantic_coherence", "decision_mode", "ranking_validity"],
      "properties": {
        "candidate_count": {"type": "integer", "minimum": 0},
        "as_of": {"type": "string"},
        "semantic_coherence": {"type": "string"},
        "decision_mode": {"type": "string"},
        "ranking_validity": {"type": "string"},
        "score_gap_to_runner_up": {"type": ["number", "null"]}
      },
      "additionalProperties": true
    },
    "observed_facts": {
      "type": "object",
      "required": ["candidates", "research_debt", "readiness_matrix"],
      "properties": {
        "candidates": {
          "type": "array",
          "items": {"$ref": "#/$defs/candidate"}
        },
        "research_debt": {
          "type": "array",
          "items": {"type": "object"}
        },
        "readiness_matrix": {
          "type": "array",
          "items": {"type": "object"}
        }
      },
      "additionalProperties": true
    },
    "forecast_variables": {
      "type": "array",
      "minItems": 3,
      "items": {"$ref": "#/$defs/forecast_variable"}
    },
    "strategy_questions": {
      "type": "array",
      "minItems": 3,
      "items": {"type": "string"}
    },
    "laplace_execution": {
      "type": "object",
      "required": ["must_read", "required_output_sections", "claim_policy"],
      "properties": {
        "must_read": {
          "type": "array",
          "items": {"type": "string"}
        },
        "required_output_sections": {
          "type": "array",
          "items": {"type": "string"}
        },
        "claim_policy": {"type": "string"}
      },
      "additionalProperties": true
    },
    "ledger_seed": {
      "type": "object",
      "required": ["question", "horizon", "object", "geography", "decision_use", "claims"],
      "properties": {
        "question": {"type": "string"},
        "horizon": {"type": "string"},
        "object": {"type": "string"},
        "geography": {"type": "string"},
        "decision_use": {"type": "string"},
        "claims": {
          "type": "array",
          "items": {"type": "object"}
        }
      },
      "additionalProperties": true
    },
    "discovery_context": {
      "type": "object",
      "required": ["candidate_funnel_path", "candidate_funnel_present", "policy"],
      "properties": {
        "candidate_funnel_path": {"type": "string"},
        "candidate_funnel_present": {"type": "boolean"},
        "policy": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "required": [
        "symbol",
        "market",
        "rating_cap",
        "research_priority_score",
        "action_priority_score",
        "action_readiness",
        "primary_gate",
        "data_evidence_cap",
        "ai_review_status",
        "market_implied_growth",
        "evidence_supported_growth",
        "research_debt_count"
      ],
      "properties": {
        "symbol": {"type": "string"},
        "name": {"type": "string"},
        "market": {"type": "string"},
        "rating_cap": {"type": "string"},
        "research_priority_score": {"type": ["number", "null"]},
        "action_priority_score": {"type": ["number", "null"]},
        "action_readiness": {"type": "string"},
        "primary_gate": {"type": "string"},
        "primary_gate_class": {"type": "string"},
        "data_evidence_cap": {"type": "string"},
        "ai_review_status": {"type": "string"},
        "market_implied_growth": {"type": "string"},
        "evidence_supported_growth": {"type": "string"},
        "research_debt_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "forecast_variable": {
      "type": "object",
      "required": ["variable", "role", "direction", "observability", "change_speed", "dominant_lens", "confidence", "why"],
      "properties": {
        "variable": {"type": "string"},
        "role": {"type": "string"},
        "direction": {"type": "string"},
        "observability": {"type": "string"},
        "change_speed": {"type": "string"},
        "dominant_lens": {"type": "string"},
        "confidence": {"type": "string"},
        "why": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
