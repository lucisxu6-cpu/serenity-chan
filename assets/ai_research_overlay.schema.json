{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Serenity Chan AI Research Overlay",
  "type": "object",
  "required": [
    "symbol",
    "as_of_date",
    "layer",
    "bottleneck_reason",
    "revenue_transmission",
    "serenity_fit",
    "key_evidence_refs",
    "contrary_evidence",
    "research_questions",
    "ai_confidence"
  ],
  "properties": {
    "symbol": { "type": "string", "minLength": 1 },
    "as_of_date": { "type": "string", "minLength": 1 },
    "layer": { "type": "string", "minLength": 1 },
    "bottleneck_reason": { "type": "string", "minLength": 1 },
    "revenue_transmission": { "type": "string", "minLength": 1 },
    "serenity_fit": { "type": "number", "minimum": 0, "maximum": 1 },
    "layer_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "company_fit": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "evidence_supported_growth": { "type": "string", "enum": ["H0", "H1", "H2", "H3", "H4", "H5", "UNKNOWN"] },
    "h4_h5_evidence_bar_met": { "type": "boolean" },
    "required_next_evidence": { "type": "string" },
    "posterior_basis": { "type": "string" },
    "ai_confidence": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
    "key_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence_ref" }
    },
    "contrary_evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "research_questions": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "evidence_ref": {
      "type": "object",
      "required": ["claim", "source_ref", "source_level", "confidence"],
      "properties": {
        "claim": { "type": "string", "minLength": 1 },
        "source_ref": { "type": "string", "minLength": 1 },
        "source_level": { "type": "string", "enum": ["L0", "L1", "L2", "L3", "L4"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
