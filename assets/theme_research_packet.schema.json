{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Serenity Theme Research Packet",
  "type": "object",
  "required": [
    "contract_type",
    "schema_version",
    "theme",
    "generated_at",
    "universe_path",
    "candidate_count",
    "candidate_symbols",
    "candidate_expansion_status",
    "layer_coverage",
    "value_chain_layers",
    "per_candidate_research_tasks",
    "direction_research_questions",
    "macro_evidence_tasks",
    "falsification_questions",
    "candidate_expansion_policy",
    "next_step"
  ],
  "properties": {
    "contract_type": { "type": "string", "const": "serenity_theme_research_packet" },
    "schema_version": { "type": "string", "const": "1.0" },
    "theme": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "universe_path": { "type": "string" },
    "candidate_count": { "type": "integer", "minimum": 1 },
    "candidate_expansion_status": {
      "type": "string",
      "enum": ["CURATED_FULL", "CURATED_INITIAL", "AI_EXPANSION_REQUIRED"]
    },
    "layer_coverage": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "candidate_symbols": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "value_chain_layers": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "object" }
    },
    "per_candidate_research_tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["symbol", "name", "layer", "evidence_tasks", "downgrade_triggers"],
        "properties": {
          "symbol": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "layer": { "type": "string", "minLength": 1 },
          "evidence_tasks": {
            "type": "array",
            "minItems": 3,
            "items": { "type": "string", "minLength": 1 }
          },
          "downgrade_triggers": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": true
      }
    },
    "direction_research_questions": {
      "type": "array",
      "minItems": 5,
      "items": { "type": "string", "minLength": 1 }
    },
    "macro_evidence_tasks": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string", "minLength": 1 }
    },
    "falsification_questions": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string", "minLength": 1 }
    },
    "candidate_expansion_policy": {
      "type": "object",
      "required": ["minimum_deep_scan_candidates", "required_layer_coverage", "exclusion_rule"],
      "properties": {
        "minimum_deep_scan_candidates": { "type": "integer", "minimum": 1 },
        "required_layer_coverage": { "type": "string", "minLength": 1 },
        "exclusion_rule": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "next_step": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
