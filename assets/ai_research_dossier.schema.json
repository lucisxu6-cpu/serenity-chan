{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Serenity Chan AI Research Dossier",
  "type": "object",
  "required": [
    "contract_type",
    "schema_version",
    "symbol",
    "as_of_date",
    "research_status",
    "source_reading_log",
    "research_path",
    "observed",
    "inferred",
    "judgment",
    "claim_graph",
    "causal_chain",
    "same_layer_comparison",
    "bear_case",
    "scenario_view",
    "trigger_table",
    "action_conditions",
    "confidence_dampers",
    "overlay_projection"
  ],
  "properties": {
    "contract_type": { "type": "string", "const": "serenity_ai_research_dossier" },
    "schema_version": { "type": "string", "const": "1.0" },
    "symbol": { "type": "string", "minLength": 1 },
    "as_of_date": { "type": "string", "minLength": 1 },
    "research_status": {
      "type": "string",
      "enum": ["COMPLETED", "FAILED_INSUFFICIENT_EVIDENCE", "CONFLICT_WITH_DATA"]
    },
    "source_reading_log": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source_reading" }
    },
    "research_path": {
      "type": "object",
      "required": ["core_question", "decision_use", "hypotheses", "evidence_tests", "unresolved_questions"],
      "properties": {
        "core_question": { "type": "string", "minLength": 1 },
        "decision_use": { "type": "string", "minLength": 1 },
        "base_rate_anchor": { "type": "string" },
        "reflexivity_check": { "type": "string" },
        "hypotheses": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/hypothesis" }
        },
        "evidence_tests": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/evidence_test" }
        },
        "unresolved_questions": { "$ref": "#/$defs/non_empty_string_array" }
      },
      "additionalProperties": false
    },
    "observed": { "$ref": "#/$defs/non_empty_string_array" },
    "inferred": { "$ref": "#/$defs/non_empty_string_array" },
    "judgment": { "$ref": "#/$defs/non_empty_string_array" },
    "claim_graph": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/claim_node" }
    },
    "causal_chain": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/causal_step" }
    },
    "same_layer_comparison": {
      "type": "array",
      "items": { "$ref": "#/$defs/comparison_item" }
    },
    "bear_case": { "$ref": "#/$defs/non_empty_string_array" },
    "scenario_view": {
      "type": "object",
      "required": ["base", "upside", "downside"],
      "properties": {
        "base": { "$ref": "#/$defs/scenario" },
        "upside": { "$ref": "#/$defs/scenario" },
        "downside": { "$ref": "#/$defs/scenario" }
      },
      "additionalProperties": false
    },
    "trigger_table": {
      "type": "object",
      "required": ["30d", "90d", "180d"],
      "properties": {
        "30d": { "$ref": "#/$defs/non_empty_string_array" },
        "90d": { "$ref": "#/$defs/non_empty_string_array" },
        "180d": { "$ref": "#/$defs/non_empty_string_array" }
      },
      "additionalProperties": false
    },
    "action_conditions": {
      "type": "object",
      "required": ["upgrade_to_action", "add_or_size_up", "trim_or_exit", "stay_research_only"],
      "properties": {
        "upgrade_to_action": { "$ref": "#/$defs/non_empty_string_array" },
        "add_or_size_up": { "$ref": "#/$defs/non_empty_string_array" },
        "trim_or_exit": { "$ref": "#/$defs/non_empty_string_array" },
        "stay_research_only": { "$ref": "#/$defs/non_empty_string_array" }
      },
      "additionalProperties": false
    },
    "confidence_dampers": { "$ref": "#/$defs/non_empty_string_array" },
    "overlay_projection": {
      "type": "object",
      "required": [
        "layer",
        "bottleneck_reason",
        "revenue_transmission",
        "serenity_fit",
        "evidence_supported_growth",
        "required_next_evidence",
        "posterior_basis",
        "ai_confidence",
        "thesis_quality_delta",
        "evidence_confidence_delta",
        "risk_adjustment",
        "action_condition_summary"
      ],
      "properties": {
        "layer": { "type": "string", "minLength": 1 },
        "bottleneck_reason": { "type": "string", "minLength": 1 },
        "revenue_transmission": { "type": "string", "minLength": 1 },
        "serenity_fit": { "type": "number", "minimum": 0, "maximum": 1 },
        "layer_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "company_fit": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "evidence_supported_growth": {
          "type": "string",
          "enum": ["H0", "H1", "H2", "H3", "H4", "H5", "UNKNOWN"]
        },
        "h4_h5_evidence_bar_met": { "type": "boolean" },
        "required_next_evidence": { "type": "string", "minLength": 1 },
        "posterior_basis": { "type": "string", "minLength": 1 },
        "ai_confidence": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
        "thesis_quality_delta": { "type": "number", "minimum": -8, "maximum": 8 },
        "evidence_confidence_delta": { "type": "number", "minimum": -8, "maximum": 8 },
        "risk_adjustment": { "type": "number", "minimum": -8, "maximum": 8 },
        "action_condition_summary": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "source_reading": {
      "type": "object",
      "required": ["source_ref", "source_level", "read_status", "finding"],
      "properties": {
        "source_ref": { "type": "string", "minLength": 1 },
        "source_level": { "type": "string", "enum": ["L0", "L1", "L2", "L3", "L4"] },
        "read_status": {
          "type": "string",
          "enum": ["READ", "PARTIAL_READ", "UNAVAILABLE", "NOT_DECISION_RELEVANT"]
        },
        "finding": { "type": "string", "minLength": 1 },
        "claim_boundary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "claim_node": {
      "type": "object",
      "required": ["claim", "supporting_refs", "opposing_refs", "status", "decision_impact"],
      "properties": {
        "claim": { "type": "string", "minLength": 1 },
        "supporting_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "opposing_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "status": {
          "type": "string",
          "enum": ["SUPPORTED", "PARTIAL", "CONFLICTED", "UNSUPPORTED"]
        },
        "decision_impact": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "hypothesis": {
      "type": "object",
      "required": ["hypothesis", "current_view", "why_it_matters", "evidence_needed"],
      "properties": {
        "hypothesis": { "type": "string", "minLength": 1 },
        "current_view": {
          "type": "string",
          "enum": ["SUPPORTED", "PARTIAL", "CONFLICTED", "UNTESTED"]
        },
        "why_it_matters": { "type": "string", "minLength": 1 },
        "evidence_needed": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "evidence_test": {
      "type": "object",
      "required": ["test", "method", "current_result", "evidence_status", "source_refs"],
      "properties": {
        "test": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "current_result": { "type": "string", "minLength": 1 },
        "evidence_status": {
          "type": "string",
          "enum": ["DIRECT", "LEAD", "INFERRED", "MISSING", "CONFLICTED"]
        },
        "source_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "causal_step": {
      "type": "object",
      "required": ["step", "mechanism", "evidence_status"],
      "properties": {
        "step": { "type": "string", "minLength": 1 },
        "mechanism": { "type": "string", "minLength": 1 },
        "evidence_status": {
          "type": "string",
          "enum": ["DIRECT", "LEAD", "INFERRED", "MISSING", "CONFLICTED"]
        }
      },
      "additionalProperties": false
    },
    "comparison_item": {
      "type": "object",
      "required": ["peer", "comparison_axis", "relative_position", "evidence_needed"],
      "properties": {
        "peer": { "type": "string", "minLength": 1 },
        "comparison_axis": { "type": "string", "minLength": 1 },
        "relative_position": { "type": "string", "minLength": 1 },
        "evidence_needed": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "scenario": {
      "type": "object",
      "required": ["summary", "probability", "conditions"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "probability": { "type": "number", "minimum": 0, "maximum": 1 },
        "conditions": { "$ref": "#/$defs/non_empty_string_array" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
