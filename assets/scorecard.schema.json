{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SerenityChanScorecard",
  "type": "object",
  "required": [
    "ticker",
    "market",
    "as_of_date",
    "data_quality",
    "serenity",
    "evidence",
    "fundamentals",
    "valuation",
    "technical",
    "risk",
    "penalties"
  ],
  "properties": {
    "ticker": {"type": "string", "minLength": 1},
    "company": {"type": "string"},
    "market": {"type": "string", "enum": ["CN_A", "US", "HK", "GLOBAL", "OTHER", "UNKNOWN"]},
    "as_of_date": {"type": "string", "pattern": "^(\\d{4}-\\d{2}-\\d{2}|YYYY-MM-DD)$"},
    "data_quality": {"$ref": "#/$defs/module"},
    "serenity": {"$ref": "#/$defs/module"},
    "evidence": {"$ref": "#/$defs/module"},
    "fundamentals": {"$ref": "#/$defs/module"},
    "valuation": {"$ref": "#/$defs/module"},
    "technical": {"$ref": "#/$defs/module"},
    "risk": {"$ref": "#/$defs/module"},
    "penalties": {
      "type": "object",
      "properties": {
        "only_weak_evidence": {"type": "boolean"},
        "missing_latest_quote": {"type": "boolean"},
        "missing_price_history": {"type": "boolean"},
        "missing_latest_financials": {"type": "boolean"},
        "unverified_customer_claim": {"type": "boolean"},
        "price_source_conflict_gt_2pct": {"type": "boolean"},
        "major_dilution_or_governance_red_flag": {"type": "boolean"},
        "technical_escape_overheat": {"type": "boolean"},
        "h4_h5_without_strong_evidence": {"type": "boolean"},
        "market_implied_growth_exceeds_evidence": {"type": "boolean"},
        "fundamental_falsified": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "evidence_notes": {
      "type": "array",
      "items": {"$ref": "#/$defs/evidence_note"}
    },
    "falsification_points": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "module": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "number",
        "minimum": 0,
        "maximum": 5
      }
    },
    "evidence_note": {
      "type": "object",
      "properties": {
        "claim": {"type": "string"},
        "source": {"type": "string"},
        "source_level": {"type": "string", "enum": ["L0", "L1", "L2", "L3", "L4", ""]},
        "supports": {"type": "string"},
        "missing_proof": {"type": "string"},
        "confidence": {"type": "string", "enum": ["Strong", "Medium", "Weak", "Unverified", ""]}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
