{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SerenityChanFalsificationDashboard",
  "type": "object",
  "required": [
    "symbol",
    "market",
    "as_of_date",
    "thesis",
    "rating",
    "rating_cap",
    "monitors"
  ],
  "properties": {
    "symbol": {"type": "string", "minLength": 1},
    "company": {"type": "string"},
    "market": {"type": "string", "enum": ["CN_A", "US", "HK", "GLOBAL", "OTHER", "UNKNOWN"]},
    "currency": {"type": "string"},
    "as_of_date": {"type": "string", "pattern": "^(\\d{4}-\\d{2}-\\d{2}|YYYY-MM-DD)$"},
    "rating": {"$ref": "#/$defs/rating"},
    "rating_cap": {"$ref": "#/$defs/rating"},
    "thesis": {
      "type": "object",
      "required": ["summary", "market_implied_growth", "evidence_supported_growth"],
      "properties": {
        "summary": {"type": "string"},
        "market_implied_growth": {"$ref": "#/$defs/growth_hypothesis"},
        "evidence_supported_growth": {"$ref": "#/$defs/growth_hypothesis"},
        "key_assumption": {"type": "string"},
        "missing_proof": {"type": "string"}
      }
    },
    "monitors": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/monitor"}
    },
    "evidence_links": {
      "type": "array",
      "items": {"$ref": "#/$defs/evidence_link"}
    },
    "notes": {"type": "string"}
  },
  "$defs": {
    "rating": {"type": "string", "enum": ["S", "A", "B", "C", "D", "OBSERVE_ONLY"]},
    "growth_hypothesis": {"type": "string", "enum": ["H0", "H1", "H2", "H3", "H4", "H5", "UNKNOWN"]},
    "monitor": {
      "type": "object",
      "required": [
        "id",
        "category",
        "claim",
        "falsification_trigger",
        "source_required",
        "check_frequency",
        "status",
        "action_if_triggered"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "category": {
          "type": "string",
          "enum": ["demand", "financials", "customer", "capacity", "valuation", "technical", "governance", "source_quality"]
        },
        "claim": {"type": "string"},
        "falsification_trigger": {"type": "string"},
        "source_required": {"type": "string"},
        "check_frequency": {"type": "string"},
        "status": {"type": "string", "enum": ["OK", "WATCH", "TRIGGERED", "STALE", "UNKNOWN"]},
        "latest_check": {"type": "string"},
        "action_if_triggered": {"type": "string"}
      }
    },
    "evidence_link": {
      "type": "object",
      "required": ["claim", "source", "source_level"],
      "properties": {
        "claim": {"type": "string"},
        "source": {"type": "string"},
        "source_level": {"type": "string", "enum": ["L0", "L1", "L2", "L3", "L4"]},
        "confidence": {"type": "string", "enum": ["Strong", "Medium", "Weak", "Unverified"]}
      }
    }
  },
  "additionalProperties": true
}
