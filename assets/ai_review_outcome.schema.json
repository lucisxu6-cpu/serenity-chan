{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Serenity Chan AI Review Outcome",
  "type": "object",
  "required": [
    "symbol",
    "as_of_date",
    "ai_review_status",
    "reason"
  ],
  "properties": {
    "symbol": { "type": "string", "minLength": 1 },
    "as_of_date": { "type": "string", "minLength": 1 },
    "ai_review_status": {
      "type": "string",
      "enum": ["FAILED_INSUFFICIENT_EVIDENCE", "CONFLICT_WITH_DATA", "SKIPPED_QUICK_AUDIT"]
    },
    "reason": { "type": "string", "minLength": 1 },
    "required_evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "conflicting_fields": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "source_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "research_questions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
