{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Serenity Chan Candidate Comparison Output",
  "type": "object",
  "required": [
    "comparison_scope",
    "candidates",
    "data_acquisition_summary",
    "serenity_layer_matrix",
    "financial_quality_matrix",
    "valuation_input_matrix",
    "currency_normalization_matrix",
    "growth_hypothesis_matrix",
    "technical_timing_matrix",
    "capital_actions",
    "data_consumption_audit",
    "readiness_matrix",
    "research_debt",
    "candidate_priority_ranking",
    "final_decision"
  ],
  "properties": {
    "comparison_scope": {
      "type": "object",
      "required": ["candidate_count", "as_of", "basis"],
      "properties": {
        "candidate_count": { "type": "integer", "minimum": 2 },
        "as_of": { "type": "string" },
        "basis": { "type": "string" }
      },
      "additionalProperties": true
    },
    "candidates": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["symbol", "market", "currency", "rating_cap", "data_package_path"],
        "properties": {
          "symbol": { "type": "string" },
          "name": { "type": "string" },
          "market": { "type": "string" },
          "currency": { "type": "string" },
          "rating_cap": { "$ref": "#/$defs/rating" },
          "data_package_path": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "data_acquisition_summary": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/candidate_table_row" }
    },
    "serenity_layer_matrix": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "symbol",
          "layer",
          "bottleneck_reason",
          "layer_score",
          "company_fit",
          "revenue_transmission",
          "evidence_gap"
        ],
        "properties": {
          "symbol": { "type": "string" },
          "layer": { "type": "string" },
          "bottleneck_reason": { "type": "string" },
          "layer_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
          "company_fit": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
          "revenue_transmission": { "type": "string" },
          "evidence_gap": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "financial_quality_matrix": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/candidate_table_row" }
    },
    "valuation_input_matrix": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "symbol",
          "valuation_input_ref",
          "status",
          "valuation_stage",
          "valuation_confidence",
          "regular_market_price",
          "total_shares",
          "total_market_cap",
          "currency",
          "as_of_date",
          "source_name",
          "source_level",
          "source_basis",
          "share_count_basis",
          "market_cap_basis",
          "verification_needed",
          "warnings",
          "errors"
        ],
        "properties": {
          "symbol": { "type": "string" },
          "valuation_input_ref": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["OK", "PARTIAL", "STALE", "FAILED", "PENDING", "NOT_APPLICABLE", "NOT_REQUESTED"]
          },
          "valuation_stage": {
            "type": "string",
            "enum": ["unavailable", "preflight", "verified_l0", "verified_l1", "deep_valuation"]
          },
          "valuation_confidence": {
            "type": "string",
            "enum": ["blocked", "low", "medium", "high"]
          },
          "regular_market_price": { "type": ["number", "null"] },
          "total_shares": { "type": ["number", "null"] },
          "float_shares": { "type": ["number", "null"] },
          "total_market_cap": { "type": ["number", "null"] },
          "float_market_cap": { "type": ["number", "null"] },
          "currency": { "type": "string" },
          "as_of_date": { "type": "string" },
          "source_name": { "type": "string" },
          "source_level": { "type": "string" },
          "source_basis": { "type": "string" },
          "share_count_basis": { "type": "string" },
          "market_cap_basis": { "type": "string" },
          "verification_needed": { "type": "boolean" },
          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          },
          "errors": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    },
    "currency_normalization_matrix": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "symbol",
          "source_currency",
          "target_currency",
          "original_total_market_cap",
          "normalized_total_market_cap",
          "fx_rate",
          "fx_rate_direction",
          "fx_as_of_date",
          "fx_source",
          "fx_source_level",
          "normalization_stage",
          "normalization_status",
          "reason_code",
          "warnings",
          "errors"
        ],
        "properties": {
          "symbol": { "type": "string" },
          "source_currency": { "type": "string" },
          "target_currency": { "type": "string" },
          "original_total_market_cap": { "type": ["number", "null"] },
          "normalized_total_market_cap": { "type": ["number", "null"] },
          "fx_rate": { "type": ["number", "null"] },
          "fx_rate_direction": { "type": "string" },
          "fx_as_of_date": { "type": "string" },
          "fx_source": { "type": "string" },
          "fx_source_level": { "type": "string" },
          "normalization_stage": { "type": "string", "enum": ["same_currency", "preflight_fx"] },
          "normalization_status": { "type": "string", "enum": ["OK", "NOT_REQUIRED", "DATA_GATED", "FAILED"] },
          "reason_code": { "type": "string" },
          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          },
          "errors": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    },
    "growth_hypothesis_matrix": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "symbol",
          "valuation_input_ref",
          "market_implied_growth",
          "evidence_supported_growth",
          "gap",
          "h4_h5_evidence_bar_met",
          "valuation_stage",
          "valuation_confidence",
          "required_next_evidence"
        ],
        "properties": {
          "symbol": { "type": "string" },
          "valuation_input_ref": { "type": "string" },
          "market_implied_growth": {
            "type": "string",
            "enum": ["H0", "H1", "H2", "H3", "H4", "H5", "UNKNOWN"]
          },
          "evidence_supported_growth": {
            "type": "string",
            "enum": ["H0", "H1", "H2", "H3", "H4", "H5", "UNKNOWN"]
          },
          "gap": { "type": "string" },
          "h4_h5_evidence_bar_met": { "type": "boolean" },
          "required_next_evidence": { "type": "string" },
          "total_market_cap": { "type": ["number", "null"] },
          "original_total_market_cap": { "type": ["number", "null"] },
          "normalized_total_market_cap": { "type": ["number", "null"] },
          "total_shares": { "type": ["number", "null"] },
          "revenue_amount": { "type": ["number", "null"] },
          "net_income_amount": { "type": ["number", "null"] },
          "financial_statement_unit": { "type": "string" },
          "financial_unit_multiplier": { "type": ["number", "null"] },
          "currency_normalization_status": { "type": "string" },
          "fx_rate": { "type": ["number", "null"] },
          "pe_preflight": { "type": ["number", "null"] },
          "ps_preflight": { "type": ["number", "null"] },
          "valuation_stage": {
            "type": "string",
            "enum": ["unavailable", "preflight", "verified_l0", "verified_l1", "deep_valuation"]
          },
          "valuation_confidence": {
            "type": "string",
            "enum": ["blocked", "low", "medium", "high"]
          },
          "posterior_basis": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "technical_timing_matrix": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/candidate_table_row" }
    },
    "capital_actions": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/candidate_table_row" }
    },
    "data_consumption_audit": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["symbol", "dataset", "raw_status", "row_count", "consumed_by", "consumption_status", "selected_period", "selection_rule", "warnings", "reason_code", "required_transform", "blocked_matrices", "ranking_impact"],
        "properties": {
          "symbol": { "type": "string" },
          "dataset": { "type": "string" },
          "raw_status": {
            "type": "string",
            "enum": ["OK", "PARTIAL", "STALE", "FAILED", "PENDING", "NOT_APPLICABLE", "NOT_REQUESTED"]
          },
          "row_count": { "type": "integer", "minimum": 0 },
          "consumed_by": {
            "type": "array",
            "items": { "type": "string" }
          },
          "consumption_status": {
            "type": "string",
            "enum": ["OK", "PARTIAL", "DATA_GATED", "MISMATCH"]
          },
          "selected_period": { "type": "string" },
          "selection_rule": { "type": "string" },
          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          },
          "reason_code": { "type": "string" },
          "required_transform": { "type": "string" },
          "blocked_matrices": {
            "type": "array",
            "items": { "type": "string" }
          },
          "ranking_impact": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "readiness_matrix": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "symbol",
          "fetch_status",
          "research_readiness",
          "action_readiness",
          "primary_gate",
          "data_evidence_cap",
          "decision_grade",
          "reason_codes"
        ],
        "properties": {
          "symbol": { "type": "string" },
          "fetch_status": { "type": "string", "enum": ["PASS", "PARTIAL", "FAILED"] },
          "research_readiness": { "type": "string", "enum": ["HIGH", "PARTIAL", "NOT_READY"] },
          "action_readiness": { "$ref": "#/$defs/action_readiness" },
          "primary_gate": {
            "type": "string",
            "enum": ["NONE", "DATA_GATED", "EVIDENCE_GATED", "VALUATION_GATED", "AI_REVIEW_GATED", "BUY_POINT_GATED", "CAPITAL_ACTION_GATED"]
          },
          "data_evidence_cap": { "$ref": "#/$defs/rating" },
          "decision_grade": { "type": "boolean" },
          "reason_codes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    },
    "research_debt": {
      "type": "array",
      "items": { "$ref": "#/$defs/candidate_table_row" }
    },
    "candidate_priority_ranking": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "rank",
          "symbol",
          "priority_score",
          "research_priority_score",
          "action_priority_score",
          "rating_cap",
          "decision_grade",
          "action_readiness",
          "action_gate",
          "key_reason"
        ],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "symbol": { "type": "string" },
          "priority_score": { "type": "number", "minimum": 0, "maximum": 100 },
          "research_priority_score": { "type": "number", "minimum": 0, "maximum": 100 },
          "action_priority_score": { "type": "number", "minimum": 0, "maximum": 100 },
          "rating_cap": { "$ref": "#/$defs/rating" },
          "decision_grade": { "type": "boolean" },
          "action_readiness": { "$ref": "#/$defs/action_readiness" },
          "action_gate": { "$ref": "#/$defs/action_gate" },
          "key_reason": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "final_decision": {
      "type": "object",
      "required": [
        "top_candidate",
        "decision_mode",
        "score_gap_to_runner_up",
        "candidate_count_warning",
        "ranking_validity",
        "decision",
        "next_research_actions"
      ],
      "properties": {
        "top_candidate": { "type": "string" },
        "decision_mode": {
          "type": "string",
          "enum": ["single_candidate", "clear_top_candidate", "tentative_top_candidate", "candidate_cluster", "comparison_not_decision_grade"]
        },
        "score_gap_to_runner_up": { "type": ["number", "null"] },
        "candidate_count_warning": { "type": "string" },
        "ranking_validity": {
          "type": "object",
          "required": ["status", "reason", "blocked_by", "partial_axes"],
          "properties": {
            "status": { "type": "string", "enum": ["VALID", "PARTIAL", "INVALID"] },
            "reason": { "type": "string" },
            "blocked_by": {
              "type": "array",
              "items": { "type": "string" }
            },
            "partial_axes": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        },
        "decision": { "type": "string" },
        "next_research_actions": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "rating": {
      "type": "string",
      "enum": ["S", "A", "B", "C", "D", "OBSERVE_ONLY"]
    },
    "action_readiness": {
      "type": "string",
      "enum": [
        "CORE_CANDIDATE",
        "STRONG_OBSERVE",
        "CANDIDATE_POOL",
        "WAIT_FOR_BUY_POINT",
        "DATA_GATED",
        "RESEARCH_GATED",
        "LEAD_TRACKING",
        "ELIMINATE",
        "OBSERVE_ONLY"
      ]
    },
    "candidate_table_row": {
      "type": "object",
      "required": ["symbol"],
      "properties": {
        "symbol": { "type": "string" }
      },
      "additionalProperties": true
    },
    "action_gate": {
      "type": "object",
      "required": ["primary_gate", "primary_gate_class", "gate_classes", "secondary_gates", "blocking_datasets", "blocking_reasons"],
      "properties": {
        "state": { "type": "string" },
        "primary_gate": {
          "type": "string",
          "enum": ["NONE", "DATA_GATED", "EVIDENCE_GATED", "VALUATION_GATED", "AI_REVIEW_GATED", "BUY_POINT_GATED", "CAPITAL_ACTION_GATED"]
        },
        "primary_gate_class": {
          "type": "string",
          "enum": ["NONE", "DATA_ACQUISITION", "EVIDENCE_VALIDATION", "RESEARCH_VALIDATION", "ACTION_TIMING"]
        },
        "gate_classes": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": ["DATA_ACQUISITION", "EVIDENCE_VALIDATION", "RESEARCH_VALIDATION", "ACTION_TIMING"]
          }
        },
        "secondary_gates": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["DATA_GATED", "EVIDENCE_GATED", "VALUATION_GATED", "AI_REVIEW_GATED", "BUY_POINT_GATED", "CAPITAL_ACTION_GATED"]
          }
        },
        "blocking_datasets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blocking_reasons": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
