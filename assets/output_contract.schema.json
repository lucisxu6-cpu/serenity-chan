{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SerenityChanOutputContract",
  "type": "object",
  "required": [
    "market_route",
    "data_quality",
    "data_acquisition",
    "decision_matrix",
    "rating",
    "rating_cap",
    "evidence",
    "falsification",
    "action",
    "uncertainty"
  ],
  "properties": {
    "market_route": {
      "type": "object",
      "required": ["market", "primary_disclosure_sources", "forbidden_sources"],
      "properties": {
        "normalized_symbol": {"type": "string"},
        "market": {"type": "string", "enum": ["CN_A", "US", "HK", "GLOBAL", "OTHER", "UNKNOWN"]},
        "currency": {"type": "string"},
        "primary_disclosure_sources": {
          "type": "array",
          "items": {"type": "string"}
        },
        "forbidden_sources": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "data_quality": {
      "type": "object",
      "required": ["market_resolution", "current_price", "adjusted_history", "financials", "filings"],
      "properties": {
        "market_resolution": {"$ref": "#/$defs/status"},
        "current_price": {"$ref": "#/$defs/status"},
        "adjusted_history": {"$ref": "#/$defs/status"},
        "financials": {"$ref": "#/$defs/status"},
        "filings": {"$ref": "#/$defs/status"},
        "supply_chain_evidence": {"$ref": "#/$defs/status"}
      }
    },
    "rating": {"$ref": "#/$defs/rating"},
    "rating_cap": {"$ref": "#/$defs/rating_cap"},
    "data_acquisition": {
      "type": "object",
      "required": ["status_by_dataset", "data_gaps", "research_debt", "manual_retrieval_tasks"],
      "properties": {
        "status_by_dataset": {
          "type": "object",
          "required": ["current_quote", "price_history_adjusted", "financials", "filings_announcements"],
          "properties": {
            "current_quote": {"$ref": "#/$defs/status"},
            "price_history_adjusted": {"$ref": "#/$defs/status"},
            "financials": {"$ref": "#/$defs/status"},
            "filings_announcements": {"$ref": "#/$defs/status"}
          },
          "additionalProperties": {"$ref": "#/$defs/status"}
        },
        "data_gaps": {
          "type": "array",
          "items": {"$ref": "#/$defs/data_gap"}
        },
        "research_debt": {
          "type": "array",
          "items": {"$ref": "#/$defs/research_debt"}
        },
        "manual_retrieval_tasks": {
          "type": "array",
          "items": {"$ref": "#/$defs/manual_retrieval_task"}
        },
        "attempt_ledger_path": {"type": "string"},
        "manual_retrieval_tasks_path": {"type": "string"}
      },
      "additionalProperties": true
    },
    "decision_matrix": {
      "type": "object",
      "required": [
        "thesis_quality_score",
        "evidence_confidence_score",
        "market_payoff_score",
        "action_readiness",
        "candidate_priority_score",
        "watchlist_bucket"
      ],
      "properties": {
        "thesis_quality_score": {"type": "number", "minimum": 0, "maximum": 100},
        "evidence_confidence_score": {"type": "number", "minimum": 0, "maximum": 100},
        "market_payoff_score": {"type": "number", "minimum": 0, "maximum": 100},
        "action_readiness": {"type": "string", "enum": ["CORE_CANDIDATE", "STRONG_OBSERVE", "CANDIDATE_POOL", "WAIT_FOR_BUY_POINT", "DATA_GATED", "LEAD_TRACKING", "ELIMINATE", "OBSERVE_ONLY"]},
        "candidate_priority_score": {"type": "number", "minimum": 0, "maximum": 100},
        "watchlist_bucket": {"type": "string", "enum": ["CORE_CANDIDATE", "STRONG_OBSERVE", "CANDIDATE_POOL", "DATA_GATED", "LEAD_TRACKING", "ELIMINATE", "OBSERVE_ONLY"]}
      },
      "additionalProperties": true
    },
    "evidence": {
      "type": "array",
      "items": {"$ref": "#/$defs/evidence"}
    },
    "falsification": {
      "type": "array",
      "items": {"type": "string"}
    },
    "value_chain_layer_rank": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["layer", "bottleneck_reason"],
        "properties": {
          "layer": {"type": "string"},
          "bottleneck_reason": {"type": "string"},
          "candidate_count": {"type": "integer", "minimum": 0}
        }
      }
    },
    "growth_hypothesis": {
      "type": "object",
      "required": ["market_implied", "evidence_supported"],
      "properties": {
        "market_implied": {"type": "string", "enum": ["H0", "H1", "H2", "H3", "H4", "H5", "UNKNOWN"]},
        "evidence_supported": {"type": "string", "enum": ["H0", "H1", "H2", "H3", "H4", "H5", "UNKNOWN"]},
        "h4_h5_evidence_bar_met": {"type": "boolean"},
        "posterior_basis": {"type": "string"}
      }
    },
    "action": {
      "type": "string",
      "enum": ["观察", "等待买点", "等待二买", "等待三买", "小仓试错", "核心候选", "强观察", "剔除", "不参与", "数据不足"]
    },
    "uncertainty": {
      "type": "object",
      "required": ["confirmed", "inferred", "missing", "downgrade_trigger"],
      "properties": {
        "confirmed": {"type": "string"},
        "inferred": {"type": "string"},
        "missing": {"type": "string"},
        "downgrade_trigger": {"type": "string"}
      }
    }
  },
  "$defs": {
    "status": {"type": "string", "enum": ["OK", "PARTIAL", "STALE", "FAILED", "PENDING", "NOT_APPLICABLE", "NOT_REQUESTED"]},
    "rating": {"type": "string", "enum": ["S", "A", "B", "C", "D", "OBSERVE_ONLY"]},
    "rating_cap": {"type": "string", "enum": ["S", "A", "B", "C", "D", "OBSERVE_ONLY"]},
    "evidence": {
      "type": "object",
      "required": ["claim", "source", "source_level", "confidence"],
      "properties": {
        "claim": {"type": "string"},
        "source": {"type": "string"},
        "source_level": {"type": "string", "enum": ["L0", "L1", "L2", "L3", "L4"]},
        "confidence": {"type": "string", "enum": ["Strong", "Medium", "Weak", "Unverified"]},
        "missing_proof": {"type": "string"}
      }
    },
    "data_gap": {
      "type": "object",
      "required": ["dataset", "status", "gap_type", "decision_impact", "rating_impact", "next_action"],
      "properties": {
        "dataset": {"type": "string"},
        "status": {"$ref": "#/$defs/status"},
        "gap_type": {"type": "string", "enum": ["ACCESS_FAILURE", "SCOPE_NOT_REQUESTED", "SOURCE_NOT_IMPLEMENTED", "SOURCE_UNAVAILABLE", "ISSUER_NON_DISCLOSURE", "NOT_MACHINE_READABLE", "CONFLICTING_SOURCES", "STALE_DATA", "NOT_MATERIAL", "POLICY_BLOCKED"]},
        "decision_impact": {"type": "string", "enum": ["THESIS_IMPACT", "EVIDENCE_IMPACT", "ACTION_IMPACT", "ENGINEERING_GAP", "NO_IMPACT"]},
        "rating_impact": {"type": "string"},
        "next_action": {"type": "string"}
      },
      "additionalProperties": true
    },
    "research_debt": {
      "type": "object",
      "required": ["dataset", "priority", "gap_type", "decision_impact", "next_action"],
      "properties": {
        "dataset": {"type": "string"},
        "priority": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
        "gap_type": {"type": "string"},
        "decision_impact": {"type": "string"},
        "rating_impact": {"type": "string"},
        "next_action": {"type": "string"}
      },
      "additionalProperties": true
    },
    "manual_retrieval_task": {
      "type": "object",
      "required": ["dataset", "priority", "target_source", "objective"],
      "properties": {
        "dataset": {"type": "string"},
        "priority": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
        "target_source": {"type": "string"},
        "objective": {"type": "string"},
        "acceptance_criteria": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    }
  }
}
