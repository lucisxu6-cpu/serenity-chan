{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SerenityChanOutputContract",
  "type": "object",
  "required": [
    "market_route",
    "data_quality",
    "rating",
    "rating_cap",
    "evidence",
    "falsification",
    "action",
    "uncertainty"
  ],
  "properties": {
    "market_route": {
      "type": "object",
      "required": ["market", "primary_disclosure_sources", "forbidden_sources"],
      "properties": {
        "normalized_symbol": {"type": "string"},
        "market": {"type": "string", "enum": ["CN_A", "US", "HK", "GLOBAL", "OTHER", "UNKNOWN"]},
        "currency": {"type": "string"},
        "primary_disclosure_sources": {
          "type": "array",
          "items": {"type": "string"}
        },
        "forbidden_sources": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "data_quality": {
      "type": "object",
      "required": ["market_resolution", "current_price", "adjusted_history", "financials", "filings"],
      "properties": {
        "market_resolution": {"$ref": "#/$defs/status"},
        "current_price": {"$ref": "#/$defs/status"},
        "adjusted_history": {"$ref": "#/$defs/status"},
        "financials": {"$ref": "#/$defs/status"},
        "filings": {"$ref": "#/$defs/status"},
        "supply_chain_evidence": {"$ref": "#/$defs/status"}
      }
    },
    "rating": {"$ref": "#/$defs/rating"},
    "rating_cap": {"$ref": "#/$defs/rating_cap"},
    "evidence": {
      "type": "array",
      "items": {"$ref": "#/$defs/evidence"}
    },
    "falsification": {
      "type": "array",
      "items": {"type": "string"}
    },
    "value_chain_layer_rank": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["layer", "bottleneck_reason"],
        "properties": {
          "layer": {"type": "string"},
          "bottleneck_reason": {"type": "string"},
          "candidate_count": {"type": "integer", "minimum": 0}
        }
      }
    },
    "growth_hypothesis": {
      "type": "object",
      "required": ["market_implied", "evidence_supported"],
      "properties": {
        "market_implied": {"type": "string", "enum": ["H0", "H1", "H2", "H3", "H4", "H5", "UNKNOWN"]},
        "evidence_supported": {"type": "string", "enum": ["H0", "H1", "H2", "H3", "H4", "H5", "UNKNOWN"]},
        "h4_h5_evidence_bar_met": {"type": "boolean"},
        "posterior_basis": {"type": "string"}
      }
    },
    "action": {
      "type": "string",
      "enum": ["观察", "等待买点", "等待二买", "等待三买", "小仓试错", "核心候选", "强观察", "剔除", "不参与", "数据不足"]
    },
    "uncertainty": {
      "type": "object",
      "required": ["confirmed", "inferred", "missing", "downgrade_trigger"],
      "properties": {
        "confirmed": {"type": "string"},
        "inferred": {"type": "string"},
        "missing": {"type": "string"},
        "downgrade_trigger": {"type": "string"}
      }
    }
  },
  "$defs": {
    "status": {"type": "string", "enum": ["OK", "PARTIAL", "STALE", "FAILED", "PENDING", "NOT_APPLICABLE", "NOT_REQUESTED"]},
    "rating": {"type": "string", "enum": ["S", "A", "B", "C", "D", "OBSERVE_ONLY"]},
    "rating_cap": {"type": "string", "enum": ["S", "A", "B", "C", "D", "OBSERVE_ONLY"]},
    "evidence": {
      "type": "object",
      "required": ["claim", "source", "source_level", "confidence"],
      "properties": {
        "claim": {"type": "string"},
        "source": {"type": "string"},
        "source_level": {"type": "string", "enum": ["L0", "L1", "L2", "L3", "L4"]},
        "confidence": {"type": "string", "enum": ["Strong", "Medium", "Weak", "Unverified"]},
        "missing_proof": {"type": "string"}
      }
    }
  }
}
